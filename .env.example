# ===== Project AB — environment =====

# --- Database ---
# Pick ONE driver. Default = postgres (production target).
# DB_DRIVER=sqlite                      # uncomment to use SQLite for dev
# SQLITE_PATH=./data/project-ab.sqlite  # path for SQLite file (default shown)

# Postgres connection string.
# Local docker:  postgres://arnav:arnav@localhost:5432/project_ab
# Neon prod:     postgres://USER:PASS@HOST/db?sslmode=require
DATABASE_URL=postgres://arnav:arnav@localhost:5432/project_ab

# --- Auth ---
# bcrypt hash of the 4-digit PIN. Generate via `npm run set-pin`.
PIN_HASH=

# 32+ char random secret used to sign the iron-session cookie.
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# --- App ---
APP_TIMEZONE=Asia/Kolkata

# Public site URL — used for VAPID subject + canonical links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Web Push (VAPID) ---
# Generate via `npm run vapid:generate` and paste both keys.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:arnav@e6x.io

# Required by /api/cron/reminders — Vercel injects this automatically when configured.
# For local dev, pick any random secret to manually test the route.
CRON_SECRET=

# --- Photo storage (quarterly review) ---
# Vercel Blob token. Leave empty in dev to use local /storage fallback.
BLOB_READ_WRITE_TOKEN=
